// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

/// Stores Shopify `X-Shopify-Event-Id` values so duplicate webhook deliveries are skipped (idempotent handling).
model WebhookEvent {
  eventId    String   @id
  receivedAt DateTime @default(now())
  topic      String?
}

/// Tutorial: set when the merchant has run “Sync products” so demo actions unlock.
model ShopSettings {
  shop                   String    @id
  productSyncCompletedAt DateTime?
  /// Last product created by the in-app “Generate” demo (for Edit / Delete flow).
  demoProductGid         String?
  /// Optional https://webhook.site/... URL for forwarding product webhook payloads (per shop).
  webhookDebugForwardUrl String?
}

/// Local copy of catalog rows (filled by sync + product webhooks).
model Product {
  id           String   @id @default(cuid())
  shop         String
  shopifyGid   String
  title        String
  handle       String
  status       String
  /// First variant price (Shopify decimal string), for tutorial diffs / UI.
  price        String   @default("")
  lastSyncedAt DateTime @default(now())

  @@unique([shop, shopifyGid])
}
